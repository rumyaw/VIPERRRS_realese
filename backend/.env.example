# HTTP
HTTP_ADDR=:8080

# PostgreSQL (пример для локального Docker: см. docker-compose в корне репозитория)
DATABASE_URL=postgres://tramplin:tramplin@localhost:5432/tramplin?sslmode=disable

# JWT (в продакшене — длинная случайная строка)
JWT_SECRET=change-me-in-production-min-32-chars-long

# CORS: origin фронтенда (через запятую)
CORS_ORIGINS=http://localhost:3000
